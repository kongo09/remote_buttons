{
  "config": {
    "step": {
      "user": {
        "title": "Select remote entities",
        "description": "Choose which remote entities to watch for learnt commands.",
        "data": {
          "remote_entities": "Remote entities"
        }
      },
      "reconfigure": {
        "title": "Reconfigure watched remotes",
        "data": {
          "remote_entities": "Remote entities"
        }
      }
    },
    "abort": {
      "no_remotes": "No remote entities with learn support were found.",
      "already_configured": "Remote Buttons is already configured."
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "Configure watched remotes",
        "data": {
          "remote_entities": "Remote entities"
        }
      }
    }
  },
  "entity": {
    "button": {
      "remote_command": {
        "name": "{command_name}"
      }
    },
    "number": {
      "ir_delay": {
        "name": "IR delay"
      },
      "ir_repeat": {
        "name": "IR repeat"
      }
    }
  },
  "issues": {
    "new_remote_found": {
      "title": "New remote found: {name}",
      "fix_flow": {
        "step": {
          "init": {
            "title": "Add remote: {name}",
            "description": "Do you want to add **{name}** to the list of watched remotes?"
          }
        }
      }
    }
  },
  "exceptions": {
    "send_command_failed": {
      "message": "Failed to send command \"{command}\" via {remote}."
    }
  }
